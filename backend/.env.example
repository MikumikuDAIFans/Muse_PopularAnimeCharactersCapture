# Muse_DataLoad 应用配置
# 复制此文件为 .env 并填写实际值

# ========== 应用基础配置 ==========
APP_NAME=Muse_DataLoad
APP_VERSION=0.1.0
DEBUG=false
API_PREFIX=/api

# ========== 数据库配置 ==========
# SQLite (开发环境)
DATABASE_URL=sqlite+aiosqlite:///./muse_dataload.db

# PostgreSQL (生产环境)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/muse_dataload
# DATABASE_ECHO=false

# ========== Danbooru API 配置 ==========
# 免费匿名访问（速率限制 1.5 RPS）
DANBOORU_BASE_URL=https://danbooru.donmai.us
DANBOORU_LOGIN=
DANBOORU_API_KEY=
DANBOORU_USER_AGENT=Muse_DataLoad/0.1 (+https://github.com/ckmuse)

# ========== 爬虫配置 ==========
CRAWLER_RPS=1.5
CRAWLER_THREADS=6
DOWNLOAD_PROCESSES=4
DOWNLOAD_RPS_PER_PROCESS=0.0
API_MAX_RETRIES=6
API_TIMEOUT=10,60
DOWNLOAD_TIMEOUT=15,300

# ========== 文件配置 ==========
OUTPUT_ROOT=./output
METADATA_DIR=metadata
IMAGE_DIR=images
USE_IMAGE_SUBDIRS=true
IMAGE_SUBDIR_DIVISOR=10000

# ========== 校验配置 ==========
VERIFY_MD5=true
VERIFY_FILE_SIZE=true

# ========== 服务器配置 ==========
HOST=0.0.0.0
PORT=8000